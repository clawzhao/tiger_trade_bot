# Tiger Broker API Credentials
TIGER_ID=your_tiger_id_here
ACCOUNT_ID=your_17_digit_paper_account_id
PRIVATE_KEY_PATH=./keys/rsa_private_key.pem

# Trading Environment
SANDBOX_MODE=True

# Server Ports
HEALTH_PORT=8080
METRICS_PORT=9090

# Database
DATABASE_URL=sqlite:///./trades.db

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# WebSocket
WS_ENABLED=True
WS_RECONNECT_INTERVAL=5

# Risk Parameters
MAX_POSITION_SIZE=10000
DAILY_LOSS_LIMIT=500
MAX_ORDER_RETRIES=3
